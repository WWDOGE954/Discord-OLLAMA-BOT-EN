# ============================================================
# Discord MCP-like Report Monitor Bot - Public .env.example
# Safe for GitHub. Do NOT put real token / private IDs here.
# Copy this file to .env for local use, then fill in your real values.
# ============================================================


# ============================================================
# 1. Discord bot basics
# ============================================================

# Discord Bot Token.
# NEVER commit your real token.
DISCORD_TOKEN=

# Development / target guild ID.
# Recommended for faster slash command sync during development.
GUILD_ID=

# Enable message content reading.
# Requires Discord Developer Portal -> Message Content Intent.
# true = enable normal-message moderation
# false = slash commands only
USE_MESSAGE_CONTENT=false


# ============================================================
# 2. Report / case system
# ============================================================

# Channel ID where moderation reports are sent.
# Can be a normal text channel or a ForumChannel.
REPORT_CHANNEL_ID=

# Create a discussion thread / forum post for each case.
CREATE_CASE_THREADS=true

# Thread auto-archive time in minutes.
CASE_THREAD_ARCHIVE_MINUTES=1440

# Optional report webhook URL.
# Leave empty if you use REPORT_CHANNEL_ID.
REPORT_WEBHOOK_URL=

# Avoid duplicate case spam.
# Same user + same channel + same normalized content/rule within this window
# will be merged instead of creating many new cases.
CASE_DEDUPE_SECONDS=60


# ============================================================
# 3. Role / permission settings
# ============================================================

# Admin role ID. Users with this role can access admin commands.
ADMIN_ROLE_ID=

# Warning role ID. Optional role added to warned users.
WARNING_ROLE_ID=


# ============================================================
# 4. Moderation / warning / timeout settings
# ============================================================

# Public warning in the original channel.
PUBLIC_WARNING=true

# Auto timeout.
# For public GitHub demos, default is false for safety.
# Set true in your real .env if you want automatic short timeout.
AUTO_TIMEOUT_ENABLED=false

# Three-stage recommended setup:
# 1st hit = warning
# 2nd hit = final warning
# 3rd hit within AUTO_TIMEOUT_WINDOW_SECONDS = timeout
AUTO_TIMEOUT_COUNT=3
AUTO_TIMEOUT_WINDOW_SECONDS=120
AUTO_TIMEOUT_MINUTES=1

# Away mode: when admins are not available, bot may process timeout cases.
# Keep false by default; enable with /auto_mod when needed.
AUTO_MOD_AWAY_ENABLED=false

# If auto timeout succeeds, auto-close the case as resolved.
AUTO_MOD_AUTOCLOSE_ON_TIMEOUT=true


# ============================================================
# 5. Local AI / Ollama
# ============================================================

# Ollama base URL.
OLLAMA_URL=http://localhost:11434

# Text model used by /ai, @bot, !ai, summaries, and insights.
# Example: llama3.1:8b / qwen2.5:7b / deepseek-r1:8b
OLLAMA_MODEL=llama3.1:8b

# Maximum memory items per user.
MAX_MEMORY_PER_USER=100

# General AI cooldown per user, in seconds.
AI_COMMAND_COOLDOWN_SECONDS=60

# Long-form AI cooldown per user, in seconds.
AI_LONG_COMMAND_COOLDOWN_SECONDS=600

# /ai_long collection window defaults.
AI_LONG_DEFAULT_COLLECT_SECONDS=60
AI_LONG_MAX_COLLECT_SECONDS=180


# ============================================================
# 6. AI long mode image / vision support
# ============================================================

# false = images are summarized as filename/type/size/link only.
# true = send images to an Ollama vision model before long-form analysis.
AI_VISION_ENABLED=false

# Ollama chat endpoint for vision model.
OLLAMA_VISION_URL=http://localhost:11434/api/chat

# Example vision model. Install separately in Ollama if needed.
# Example: llava:latest / moondream:latest / qwen2.5vl:latest
OLLAMA_VISION_MODEL=llava:latest

# Image safety limits.
AI_VISION_MAX_IMAGE_MB=6
AI_VISION_TIMEOUT_SECONDS=90


# ============================================================
# 7. PC status report / temperature guard
# ============================================================

# Enable scheduled PC status report.
PC_STATUS_ENABLED=false

# Channel ID where PC status reports are sent.
PC_STATUS_CHANNEL_ID=

# Report interval in minutes.
PC_STATUS_INTERVAL_MINUTES=30

# Whether to include disk status if supported by your code version.
PC_STATUS_DISK=true

# LibreHardwareMonitor Remote Web Server URL.
# LibreHardwareMonitor -> Options -> Remote Web Server -> Run
LHM_DATA_URL=http://localhost:8085/data.json

# Temperature recovery margin.
# Example: eco_temp=80 and margin=8 => recover below 72°C.
TEMP_AUTO_RECOVER_MARGIN=8


# ============================================================
# 8. User profile summary / AI insight
# ============================================================

# /my_profile ai:true cooldown in minutes.
MY_PROFILE_AI_COOLDOWN_MINUTES=60

# Default analysis days.
MY_PROFILE_AI_DAYS=7

# Per-channel scan limit for self profile.
MY_PROFILE_HISTORY_PER_CHANNEL=100

# Max messages used by self profile.
MY_PROFILE_MAX_MESSAGES=80

# /user_insight cooldown in minutes.
USER_INSIGHT_COOLDOWN_MINUTES=30

# Pro analysis scan limits.
USER_INSIGHT_PRO_HISTORY_PER_CHANNEL=500
USER_INSIGHT_PRO_MAX_MESSAGES=2000


# ============================================================
# 9. Personal music library / music playback
# ============================================================

# If set, normal members can only use /music_add in this channel.
# Leave empty to allow all channels.
MUSIC_UPLOAD_CHANNEL_ID=

# Per-user music library limit.
MUSIC_MAX_TRACKS_PER_USER=20

# Single audio file size limit in MB.
MUSIC_MAX_FILE_MB=50

# Leave voice channel automatically when queue ends.
MUSIC_LEAVE_AFTER_QUEUE=true

# Default music volume.
# 0.8 = 80%
MUSIC_DEFAULT_VOLUME=0.8

# ffmpeg executable.
# Use "ffmpeg" if ffmpeg is in PATH.
# Windows example: C:/ffmpeg/bin/ffmpeg.exe
FFMPEG_EXE=ffmpeg
